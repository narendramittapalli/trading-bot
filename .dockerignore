# State & secrets — never bake into the image
.env
.env.*
state.db
state.json
state.json.migrated

# Logs — ephemeral, written to DATA_DIR volume at runtime
logs/
*.log

# Python bytecode
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# macOS / IDE
.DS_Store
.vscode/
.idea/

# Git
.git/
.gitignore
